# Optional environment variables for Snowflake CLI, SnowSQL, or future Python connector work.
# This lab does not require a Python Snowflake connection.
# Never commit a real .env file with credentials.

SNOWFLAKE_ACCOUNT=xy12345.eu-west-1
SNOWFLAKE_USER=your_user_name
SNOWFLAKE_PASSWORD=your_password_or_leave_empty_if_using_externalbrowser
SNOWFLAKE_AUTHENTICATOR=externalbrowser

SNOWFLAKE_ROLE=RETAIL_LAB_DEVELOPER
SNOWFLAKE_WAREHOUSE=RETAIL_LAB_WH
SNOWFLAKE_DATABASE=RETAIL_LAB_DB
SNOWFLAKE_SCHEMA=RAW

